{
  "name": "@arshad-shah/swift-chart",
  "version": "1.3.1",
  "description": "Lightning-fast, zero-dependency Canvas 2D charting library with React bindings. Schema-agnostic, themeable, animated.",
  "publishConfig": {
    "access": "public"
  },
  "author": "Arshad Shah",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "keywords": [
    "chart",
    "charts",
    "charting",
    "graph",
    "canvas",
    "react",
    "visualization",
    "data-viz",
    "line-chart",
    "bar-chart",
    "pie-chart",
    "donut-chart",
    "radar-chart",
    "scatter-chart",
    "treemap",
    "gauge",
    "sparkline",
    "waterfall",
    "lightweight",
    "fast"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arshad-shah/swiftchart.git"
  },
  "homepage": "https://swiftchart.arshadshah.com",
  "bugs": {
    "url": "https://github.com/arshad-shah/swiftchart/issues"
  },
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/esm/react/index.d.ts",
        "default": "./dist/esm/react/index.js"
      },
      "require": {
        "types": "./dist/cjs/react/index.d.cts",
        "default": "./dist/cjs/react/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "react": [
        "./dist/esm/react/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || >=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "publint": "publint",
    "attw": "node scripts/attw.mjs",
    "validate": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build && pnpm run publint && pnpm run attw && pnpm run size",
    "prepublishOnly": "pnpm run validate",
    "clean": "rm -rf dist coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.31.0",
    "@eslint/js": "^9.17.0",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.5",
    "canvas": "^3.2.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "publint": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.5"
  },
  "size-limit": [
    {
      "name": "tree-shaken: LineChart only",
      "path": "dist/esm/index.js",
      "import": "{ LineChart }",
      "limit": "8.25 KB"
    },
    {
      "name": "tree-shaken: LineChart + BarChart",
      "path": "dist/esm/index.js",
      "import": "{ LineChart, BarChart }",
      "limit": "8.75 KB"
    },
    {
      "name": "tree-shaken: 6 common charts",
      "path": "dist/esm/index.js",
      "import": "{ LineChart, BarChart, PieChart, ScatterChart, GaugeChart, RadarChart }",
      "limit": "12 KB"
    },
    {
      "name": "full barrel (all 23 chart classes + helpers)",
      "path": "dist/esm/index.js",
      "limit": "23 KB"
    },
    {
      "name": "full react bundle",
      "path": "dist/esm/react/index.js",
      "limit": "23 KB"
    }
  ],
  "volta": {
    "node": "24.15.0",
    "pnpm": "10.33.2"
  },
  "pnpm": {
    "overrides": {
      "devalue@>=5.6.3 <=5.8.0": ">=5.8.1",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "vite@>=7.0.0 <=7.3.4": ">=7.3.5",
      "vite@>=8.0.0 <=8.0.15": ">=8.0.16",
      "astro@<6.4.6": ">=6.4.6 <7",
      "undici@>=7.0.0 <7.28.0": ">=7.28.0 <8",
      "linkify-it@<=5.0.0": ">=5.0.1",
      "markdown-it@<=14.1.1": ">=14.2.0",
      "js-yaml@<3.15.0": ">=3.15.0 <4",
      "js-yaml@>=4.0.0 <=4.1.1": ">=4.2.0 <5",
      "esbuild@>=0.27.3 <0.28.1": ">=0.28.1",
      "@babel/core@<=7.29.0": ">=7.29.6 <8"
    }
  }
}
