---
import Default from '@astrojs/starlight/components/SiteTitle.astro';
import libPkg from '../../../package.json';

const version = (libPkg as { version?: string }).version ?? '0.0.0';
---

<div class="sc-title">
  <Default><slot /></Default>
  <a class="sc-version"
     href="https://github.com/ArshadShah/swiftchart/releases"
     title={`v${version} — release notes`}
     aria-label={`Current version: v${version}. Open release notes`}>
    v{version}
  </a>
</div>

<style>
  .sc-title {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .sc-version {
    display: inline-flex;
    align-items: center;
    padding: 0.18rem 0.5rem;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1;
    color: #ffffff;
    background: #5b8cff;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: background 120ms;
  }
  .sc-version:hover {
    background: #4a78e8;
  }
</style>
